# App Configuration
APP_NAME=FX Signal Copier
DEBUG=false

# MetaAPI Configuration
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_account_id_here
METAAPI_TIMEOUT=30
MAX_CONNECTIONS=100
CONNECTION_IDLE_TIMEOUT=300

# Telegram Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
ADMIN_USER_IDS=123456789,987654321  # Comma-separated Telegram user IDs
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PORT=8443

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/fx_signal_copier
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# Security
ENCRYPTION_KEY=your-32-byte-base64-encryption-key-here
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Trading Configuration
DEFAULT_RISK_FACTOR=0.01
MAX_RISK_FACTOR=0.05
MIN_RISK_FACTOR=0.001
DEFAULT_MAX_POSITION_SIZE=10.0

# Rate Limiting
RATE_LIMIT_TRADES=5
RATE_LIMIT_CALCULATIONS=10
RATE_LIMIT_BALANCE=30
RATE_LIMIT_POSITIONS=20

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log